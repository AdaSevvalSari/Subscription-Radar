# Copy this file to .env and set your own values before running in production.
# For local development the app works without a .env file (safe defaults are used).

# Secret key used to sign JWT tokens.
# Change this to a long random string in any non-development environment.
JWT_SECRET=change-this-to-a-long-random-secret

# Port the server listens on (default: 3000)
# PORT=3000
